{
	"[html]": {
		"editor.defaultFormatter": "vscode.html-language-features",
	},
	"[javascript]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
	},
	"[json]": {
		"editor.defaultFormatter": "vscode.json-language-features",
	},
	"[python]": {
		"editor.defaultFormatter": "charliermarsh.ruff",
		"editor.formatOnType": true,
	},
	"[shellscript]": {
		"files.eol": "\n",
	},
	"auto-close-tag.activationOnLanguage": [
		"xml",
		"php",
		"blade",
		"ejs",
		"jinja",
		"javascript",
		"javascriptreact",
		"typescript",
		"typescriptreact",
		"plaintext",
		"markdown",
		"vue",
		"liquid",
		"erb",
		"lang-cfml",
		"cfml",
		"HTML (EEx)",
		"HTML (Eex)",
		"plist",
	],
	"colorize.include": ["*.html"],
	"diffEditor.hideUnchangedRegions.enabled": true,
	"editor.accessibilitySupport": "off",
	"editor.bracketPairColorization.enabled": true,
	"editor.cursorBlinking": "phase",
	"editor.cursorSmoothCaretAnimation": "on",
	"editor.defaultFormatter": "esbenp.prettier-vscode",
	"editor.fontFamily": "Berkeley Mono Variable",
	"editor.fontLigatures": false,
	"editor.fontSize": 13,
	"editor.guides.bracketPairs": true,
	"editor.inlineSuggest.enabled": true,
	"editor.linkedEditing": true,
	"editor.minimap.renderCharacters": false,
	"editor.smoothScrolling": true,
	"editor.suggestSelection": "first",
	"explorer.compactFolders": false,
	"explorer.confirmDelete": false,
	"files.insertFinalNewline": true,
	"files.trimTrailingWhitespace": true,
	"git.autofetch": true,
	"git.confirmSync": false,
	"git.ignoreRebaseWarning": true,
	"github.copilot.enable": {
		"*": true,
		"plaintext": false,
		"markdown": true,
		"scminput": false,
		"python": false,
		"yaml": false,
	},
	"gitlens.currentLine.enabled": false,
	"gitlens.hovers.currentLine.over": "line",
	"liveServer.settings.donotShowInfoMsg": true,
	"liveServer.settings.donotVerifyTags": true,
	"prettier.jsxSingleQuote": true,
	"prettier.printWidth": 70,
	"python.defaultInterpreterPath": "/opt/homebrew/bin/python3",
	"python.formatting.provider": "none",
	"python.linting.enabled": false,
	"security.workspace.trust.untrustedFiles": "open",
	"settingsSync.ignoredExtensions": [
		"ms-vscode.cpptools-extension-pack",
		"ms-vscode-remote.vscode-remote-extensionpack",
	],
	"settingsSync.ignoredSettings": ["editor.fontSize"],
	"sync.gist": "252c57727d687afa95b8bdacb79efe6d",
	"terminal.integrated.fontSize": 15,
	"terminal.integrated.tabs.enabled": true,
	"todo-tree.general.tagGroups": {
		"FIXME": ["FIXME", "FIX", "FIXIT"],
		"TODO": ["TODO", "TO-DO", "Todo"],
	},
	"todo-tree.general.tags": [
		"BUG",
		"HACK",
		"FIXME",
		"TODO",
		"XXX",
		"Todo",
	],
	"vsicons.dontShowNewVersionMessage": true,
	"vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",
	"workbench.colorCustomizations": {
		"editorBracketHighlight.foreground1": "#ffd700",
		"editorBracketHighlight.foreground2": "#da70d6",
		"editorBracketHighlight.foreground3": "#87cefa",
		"editorBracketHighlight.foreground4": "#ffc0cb",
		"editorBracketHighlight.foreground5": "#9acd32",
		"editorBracketHighlight.foreground6": "#9ef96a",
	},
	"workbench.editorAssociations": {},
	"workbench.iconTheme": "Monokai Pro (Filter Octagon) Icons",
	"workbench.list.smoothScrolling": true,
	"terminal.integrated.env.osx": {
		"CW_NEW_SESSION": "1",
	},
	"workbench.editor.customLabels.patterns": {
		"**/app/**/page.js": "${dirname} - page",
		"**/app/**/layout.js": "${dirname} - layout",
	},
	"terminal.integrated.fontFamily": "monospace",
	"workbench.colorTheme": "Atom One Light",
	"tailwind-fold.autoFold": false,
	"tailwind-fold.unfoldedTextOpacity": 0.7,
	"continue.telemetryEnabled": false,
	"editor.formatOnSave": true,
	"prettier.useTabs": true,
	"workbench.activityBar.location": "top",
	"editor.unicodeHighlight.ambiguousCharacters": false,
	"workbench.secondarySideBar.defaultVisibility": "hidden",
	"claudeCode.preferredLocation": "panel",
	"chat.viewSessions.orientation": "stacked",
	"aws.telemetry": false,
}
